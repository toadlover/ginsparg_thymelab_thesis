#mapped test_params directory
-params_directory_path test_params/
#rosetta-indexed anchor residue index/indices
-protein_discovery_locus 2
#fa_atr cutoff
-fa_atr_cutoff = -2
#fa_rep cutoff
-fa_rep_cutoff = 150
#ddg cutoff
-ddg_cutoff = -9
