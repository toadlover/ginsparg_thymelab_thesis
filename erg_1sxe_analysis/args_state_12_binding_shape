#keep all placements; 0 means keep all, any other integer means keep up to that integer
-best_pdbs_to_keep 0
#mapped protein system
-s 1sxe_state_12.pdb
#mapped motifs file
#/pi/summer.thyme-umw/2024_intern_lab_space/FINAL_motifs_list_filtered_2_3_2023.motifs
